# Flask Configuration
FLASK_APP=run.py
FLASK_DEBUG=
FLASK_ENV=
SECRET_KEY=

# MongoDB Configuration
MONGO_URI=
MONGO_DB_NAME=

# JWT Configuration
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES=3600

# CORS Settings
